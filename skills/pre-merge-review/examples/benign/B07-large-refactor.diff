+const wrap = <T>(fn: (req: Request, res: Response) => Promise<T>) =>
+  async (req: Request, res: Response) => {
+    try { return await fn(req, res); }
+    catch (e) {
+      if (e instanceof NotFoundError) return res.status(404).json({ error: e.message });
+      if (e instanceof ValidationError) return res.status(400).json({ error: e.message });
+      logger.error(e);
+      return res.status(500).json({ error: 'internal error' });
+    }
+  };
+
+const fetchOrFail = async <T>(query: string, args?: unknown[]): Promise<T> => {
+  const rows = await db.query<T>(query, args);
+  if (!rows || (Array.isArray(rows) && rows.length === 0)) throw new NotFoundError('not found');
+  return rows as T;
+};
 
